<Window x:Class="BacklogHealth.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Backlog Health Dashboard"
        Width="1440" Height="900"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0f172a">
  <Grid>
    <wv2:WebView2 x:Name="webView" Visibility="Hidden" />
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
      <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
      <TextBlock x:Name="statusText"
                 Text="Iniciando Backlog Health..."
                 FontSize="16" FontFamily="Segoe UI"
                 Foreground="#94a3b8"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"/>
    </StackPanel>
  </Grid>
</Window>
