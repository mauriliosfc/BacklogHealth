{
  "name": "backlog-health",
  "version": "1.0.0",
  "description": "Backlog Health Dashboard — Azure DevOps",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg . --targets node18-win-x64 --output dist/app/server.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "views/dashboard.html",
      "views/setup.html",
      "public/style.css",
      "public/app.js",
      "public/icons/icon.svg",
      "public/modules/constants.js",
      "public/modules/health.js",
      "public/modules/utils.js",
      "public/modules/theme.js",
      "public/modules/timer.js",
      "public/modules/filters.js",
      "public/modules/detail.js",
      "public/modules/daily.js",
      "public/modules/burndown.js",
      "public/modules/i18n.js",
      "public/modules/deliveryPlan.js",
      "public/modules/alias.js",
      "public/modules/cardOrder.js",
      "public/modules/teamCapacity.js",
      "public/modules/copilot.js",
      "public/i18n/pt.json",
      "public/i18n/en.json",
      "public/i18n/es.json"
    ]
  }
}
