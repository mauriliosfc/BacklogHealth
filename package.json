{
  "name": "backlog-health",
  "version": "1.0.0",
  "description": "Backlog Health Dashboard — Azure DevOps",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg server.js --targets node18-win-x64 --output dist/BacklogHealth.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "views/**/*",
      "utils/**/*"
    ],
    "scripts": [
      "config.js",
      "azureClient.js",
      "projectService.js",
      "utils/*.js"
    ]
  }
}
